[core]
editor = nvim
autocrlf = input
safecrlf = true

[user]
name = Paweł Jan Czochański
signingkey = ~/.ssh/id_ed25519_sk.pub
useConfigOnly = true

[gpg]
format = ssh

[commit]
gpgsign = true

[tag]
gpgsign = true
sort = version:refname

[push]
default = simple
gpgSign = if-asked
followTags = true
autoSetupRemote = true

[pull]
ff = only

[merge]
ff = only
conflictstyle = zdiff3
tool = meld

[mergetool]
keepBackup = false

[mergetool "meld"]
cmd = meld "$LOCAL" "$BASE" "$REMOTE" --output "$MERGED"

[diff]
tool = meld
algorithm = histogram
colorMoved = zebra
colorMovedWS = allow-indentation-change

[difftool "meld"]
cmd = meld "$LOCAL" "$REMOTE"

[fetch]
prune = true
writeCommitGraph = true

[transfer]
fsckObjects = true

[rerere]
enabled = true

[status]
showStash = true

[color]
ui = true
